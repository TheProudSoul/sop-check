.container {
  padding-bottom: 160rpx;
  min-height: 100vh;
  background: #f7f8fc;
}

/* 顶栏 */
.edit-header, .view-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
}

.cancel-btn, .save-btn {
  font-size: 30rpx;
  padding: 8rpx 16rpx;
}

.save-btn {
  color: #4ecdc4;
  font-weight: 600;
}

.back-btn {
  font-size: 30rpx;
  color: #666;
}

.header-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #4ecdc4;
}

.share-action {
  font-weight: 600;
}

.action-btn.danger {
  color: #ff6b6b;
}

/* SOP信息 */
.sop-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 24rpx;
  background: #fff;
}

.emoji-picker, .sop-emoji-large-wrap {
  margin-bottom: 16rpx;
}

.sop-emoji-large {
  font-size: 72rpx;
}

.emoji-hint {
  font-size: 22rpx;
  color: #999;
  display: block;
  text-align: center;
}

.sop-title-input, .sop-title-display {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  width: 100%;
  margin-bottom: 8rpx;
}

.sop-category-input, .sop-category-display {
  font-size: 26rpx;
  color: #636e72;
  text-align: center;
  width: 100%;
}

/* Fork来源标签 */
.forked-tag {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 6rpx 20rpx;
  background: #f0f7f7;
  border-radius: 20rpx;
}

.forked-tag-icon {
  font-size: 24rpx;
  color: #4ecdc4;
  margin-right: 6rpx;
}

.forked-tag-text {
  font-size: 22rpx;
  color: #4ecdc4;
  font-weight: 500;
}

/* 分组 */
.groups {
  padding: 16rpx 24rpx;
}

.group {
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.group-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-bottom: 1rpx solid #eee;
}

.group-name-input, .group-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
}

.group-count {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.group-delete {
  font-size: 32rpx;
  color: #ccc;
  padding: 0 8rpx;
}

/* 条目 */
.item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item:last-child {
  border-bottom: none;
}

.item-priority {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 8rpx;
  margin-right: 16rpx;
  color: #fff;
  background: #ddd;
}

.priority-must {
  background: #ff6b6b;
}

.priority-optional {
  background: #ffa726;
}

.item-content {
  flex: 1;
}

.item-name-input, .item-name {
  font-size: 30rpx;
  color: #2d3436;
  display: block;
}

.item-note-input, .item-note {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 12rpx;
}

.priority-toggle {
  font-size: 28rpx;
  padding: 4rpx;
}

.item-delete {
  font-size: 32rpx;
  color: #ccc;
  padding: 0 8rpx;
}

/* 添加按钮 */
.add-item, .add-group {
  padding: 20rpx 24rpx;
}

.add-item-text, .add-group-text {
  font-size: 28rpx;
  color: #4ecdc4;
}

.add-group-text {
  display: block;
  text-align: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx dashed #4ecdc4;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
}

.start-check-btn {
  padding: 28rpx;
  background: #4ecdc4;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.4);
}

.start-check-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

/* ========== 分享半屏弹窗 ========== */
.share-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.share-panel {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3436;
  margin-bottom: 32rpx;
}

.share-options {
  display: flex;
  gap: 40rpx;
  margin-bottom: 32rpx;
  width: 100%;
  justify-content: center;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.share-option::after {
  border: none;
}

.share-option-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.share-option-label {
  font-size: 24rpx;
  color: #636e72;
}

/* 海报 */
.poster-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 16rpx;
}

.poster-img {
  width: 80%;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.poster-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 600px;
  height: 800px;
}

.share-close {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
  padding: 12rpx 40rpx;
}
