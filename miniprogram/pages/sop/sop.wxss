/* ========== 页面 ========== */
.page {
  padding-bottom: 280rpx;
  min-height: 100vh;
  background: #f7f8fc;
}

/* ========== 查看模式顶栏 ========== */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.topbar-btn {
  font-size: 28rpx;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  transition: transform 0.15s ease, background 0.15s;
}

.topbar-btn:active {
  transform: scale(0.95);
  background: #f5f5f5;
}

.topbar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.topbar-actions {
  display: flex;
  gap: 8rpx;
}

.color-primary {
  color: #4ecdc4;
}

.color-danger {
  color: #ff6b6b;
}

/* ========== 编辑模式顶栏（深色渐变） ========== */
.topbar-dark {
  background: linear-gradient(135deg, #0f1923 0%, #1a2a3a 50%, #16213e 100%);
  border-bottom: none;
  padding: 24rpx 32rpx;
}

.topbar-title-dark {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.topbar-pill {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  transition: transform 0.15s ease, opacity 0.15s;
}

.topbar-pill:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.topbar-pill-outline {
  border: 2rpx solid rgba(255,255,255,0.5);
}

.topbar-pill-text {
  font-size: 26rpx;
  color: #fff;
}

.topbar-pill-placeholder {
  width: 120rpx;
}

/* ========== SOP 信息卡 ========== */
.info-card {
  margin: 16rpx 24rpx;
  padding: 32rpx 28rpx;
}

/* --- 编辑模式：一行式布局 --- */
.edit-header-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.emoji-box {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0faf9, #e8f8f7);
  border-radius: 24rpx;
  position: relative;
  flex-shrink: 0;
}

.emoji-interactive {
  cursor: pointer;
}

.emoji-interactive:active {
  transform: scale(0.95);
}

.emoji-display {
  font-size: 48rpx;
}

.emoji-badge {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  font-size: 18rpx;
  background: #4ecdc4;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  line-height: 1.4;
}

.edit-header-fields {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.input-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d3436;
  width: 100%;
  border-bottom: 2rpx solid #e8e8e8;
  padding-bottom: 8rpx;
}

.ph-light {
  color: #c0c0c0;
}

/* --- 分类标签横向滚动 --- */
.category-scroll {
  white-space: nowrap;
  width: 100%;
  padding: 4rpx 0;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
  background: #f4f5f7;
  margin-right: 12rpx;
  transition: all 0.2s;
}

.chip-active {
  background: #4ecdc4;
}

.chip-text {
  font-size: 24rpx;
  color: #636e72;
  white-space: nowrap;
}

.chip-active .chip-text {
  color: #fff;
  font-weight: 500;
}

.input-category-custom {
  font-size: 26rpx;
  color: #2d3436;
  border-bottom: 2rpx solid #e8e8e8;
  padding-bottom: 6rpx;
}

/* --- 查看模式 --- */
.info-emoji-row {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.info-fields {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.display-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  width: 100%;
  margin-bottom: 8rpx;
  color: #2d3436;
}

.category-row {
  margin-bottom: 4rpx;
}

.category-tag {
  padding: 6rpx 20rpx;
  background: #f0faf9;
  border-radius: 16rpx;
}

.category-tag-text {
  font-size: 24rpx;
  color: #4ecdc4;
  font-weight: 500;
}

/* 三个统计卡片横排 */
.info-stats-cards {
  display: flex;
  gap: 12rpx;
  width: 100%;
  margin-top: 20rpx;
}

.stat-mini-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
}

.stat-mini-blue { background: #e8f0fe; }
.stat-mini-green { background: #e6f8f7; }
.stat-mini-red { background: #fde8e8; }

.stat-mini-num {
  font-size: 36rpx;
  font-weight: 800;
}

.stat-mini-blue .stat-mini-num { color: #4285f4; }
.stat-mini-green .stat-mini-num { color: #4ecdc4; }
.stat-mini-red .stat-mini-num { color: #ff6b6b; }

.stat-mini-label {
  font-size: 22rpx;
  color: #636e72;
  margin-top: 4rpx;
}

/* Fork来源标签 */
.forked-tag {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 6rpx 20rpx;
  background: #f0f7f7;
  border-radius: 20rpx;
}

.forked-tag-icon {
  font-size: 24rpx;
  color: #4ecdc4;
  margin-right: 6rpx;
}

.forked-tag-text {
  font-size: 22rpx;
  color: #4ecdc4;
  font-weight: 500;
}

/* ========== 分组 ========== */
.groups {
  padding: 16rpx 24rpx;
}

.group {
  margin-bottom: 20rpx;
}

.group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  background: #fafbfc;
  border-bottom: 1rpx solid #f0f0f0;
}

.group-head-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.group-bar {
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  background: #4ecdc4;
  flex-shrink: 0;
}

/* 分组竖条循环色 */
.group-color-0 .group-bar { background: #4ecdc4; }
.group-color-1 .group-bar { background: #ffa726; }
.group-color-2 .group-bar { background: #ff6b6b; }

.input-group-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
  min-width: 0;
}

.group-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
}

.group-head-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.group-count {
  font-size: 24rpx;
  color: #999;
}

.group-collapse-btn {
  padding: 8rpx 12rpx;
}

.group-collapse-icon {
  font-size: 22rpx;
  color: #999;
}

.group-del {
  padding: 8rpx;
}

.group-del-icon {
  font-size: 32rpx;
  color: #ccc;
}

/* ========== 条目 ========== */
.item-row {
  border-bottom: 1rpx solid #f0f0f0;
}

.item-row:last-child {
  border-bottom: none;
}

/* --- 编辑模式：紧凑单行 --- */
.item-edit-row {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  gap: 12rpx;
}

.op-priority {
  padding: 8rpx;
  flex-shrink: 0;
}

.op-priority-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  display: block;
}

.dot-must { background: #ff6b6b; }
.dot-optional { background: #ffa726; }
.dot-normal { background: #ddd; }

.input-item-name-compact {
  flex: 2;
  font-size: 28rpx;
  color: #2d3436;
  min-width: 0;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 4rpx;
}

.input-item-note-compact {
  flex: 1.2;
  font-size: 24rpx;
  color: #999;
  min-width: 0;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 4rpx;
}

.op-del {
  padding: 8rpx;
  flex-shrink: 0;
}

.op-del-icon {
  font-size: 32rpx;
  color: #ccc;
}

/* --- 查看模式 --- */
.item-view-row {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
}

.priority-bar {
  width: 4rpx;
  height: 40rpx;
  border-radius: 2rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.bar-must { background: #ff6b6b; }
.bar-optional { background: #ffa726; }
.bar-normal { background: #ddd; }

.item-priority-tag {
  margin-right: 12rpx;
  flex-shrink: 0;
}

.priority-tag-text {
  font-size: 20rpx;
  font-weight: 700;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.must-text {
  color: #ff6b6b;
  background: rgba(255,107,107,0.1);
}

.optional-text {
  color: #ffa726;
  background: rgba(255,167,38,0.1);
}

.item-body {
  flex: 1;
  min-width: 0;
}

.item-name-text {
  font-size: 30rpx;
  color: #2d3436;
  display: block;
}

.item-note-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

/* ========== 添加条目按钮（醒目） ========== */
.add-item-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 18rpx 24rpx;
  background: rgba(78,205,196,0.06);
  border-top: 1rpx dashed rgba(78,205,196,0.4);
}

.add-item-icon-circle {
  width: 36rpx;
  height: 36rpx;
  line-height: 34rpx;
  text-align: center;
  font-size: 24rpx;
  color: #4ecdc4;
  border: 2rpx solid #4ecdc4;
  border-radius: 50%;
  font-weight: 600;
}

.add-item-text {
  font-size: 26rpx;
  color: #4ecdc4;
  font-weight: 500;
}

/* ========== 添加分组按钮（更醒目，区分于条目） ========== */
.add-group-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  margin-top: 8rpx;
  border: 2rpx dashed #4ecdc4;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(78,205,196,0.04), rgba(78,205,196,0.08));
}

.add-group-icon-circle {
  width: 48rpx;
  height: 48rpx;
  line-height: 46rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: #4ecdc4;
  border-radius: 50%;
  font-weight: 700;
}

.add-group-text {
  font-size: 28rpx;
  color: #4ecdc4;
  font-weight: 600;
}

/* ========== 空状态 ========== */
.empty-groups {
  text-align: center;
  padding: 60rpx 0;
}

.empty-groups-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 编辑模式底部栏 ========== */
.edit-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 20;
}

.public-row-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 8rpx;
  margin-bottom: 16rpx;
}

.save-btn-full {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #4ecdc4, #3ab8b0);
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.35);
}

.save-btn-full:active {
  transform: scale(0.98);
}

.save-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* ========== 查看模式底部操作栏 ========== */
.bottom-action {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
}

.public-row-view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.public-label {
  font-size: 26rpx;
  color: #636e72;
}

.public-toggle {
  width: 80rpx;
  height: 44rpx;
  border-radius: 22rpx;
  position: relative;
  transition: background 0.3s;
}

.toggle-on { background: #4ecdc4; }
.toggle-off { background: #d0d0d0; }

.toggle-thumb {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
  position: absolute;
  top: 4rpx;
  transition: left 0.3s;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.15);
}

.toggle-on .toggle-thumb { left: 40rpx; }
.toggle-off .toggle-thumb { left: 4rpx; }

.start-btn {
  padding: 32rpx;
  background: linear-gradient(135deg, #4ecdc4, #3ab8b0);
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  animation: breathe 3s ease-in-out infinite;
}

.start-btn-disabled {
  background: #e0e0e0;
  box-shadow: none;
  animation: none;
}

@keyframes breathe {
  0%, 100% { box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.4); }
  50% { box-shadow: 0 8rpx 36rpx rgba(78,205,196,0.6); }
}

.start-btn-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

.start-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

/* ========== Emoji 选择弹窗 ========== */
.emoji-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.emoji-panel {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.emoji-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3436;
  text-align: center;
  margin-bottom: 24rpx;
}

.emoji-scroll {
  flex: 1;
  max-height: 50vh;
}

.emoji-group-section {
  margin-bottom: 20rpx;
}

.emoji-group-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
  padding-left: 4rpx;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.emoji-cell {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  transition: background 0.15s, transform 0.15s;
}

.emoji-cell:active {
  transform: scale(0.9);
}

.emoji-cell-active {
  background: #e6f8f7;
  box-shadow: 0 0 0 2rpx #4ecdc4;
}

.emoji-cell-text {
  font-size: 40rpx;
}

.emoji-close {
  text-align: center;
  padding: 20rpx;
  margin-top: 8rpx;
}

.emoji-close-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 分享半屏弹窗 ========== */
.share-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.share-panel {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3436;
  margin-bottom: 32rpx;
}

.share-options {
  display: flex;
  gap: 40rpx;
  margin-bottom: 32rpx;
  width: 100%;
  justify-content: center;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.share-option::after {
  border: none;
}

.share-option-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.share-option-label {
  font-size: 24rpx;
  color: #636e72;
}

.poster-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 16rpx;
}

.poster-img {
  width: 80%;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.poster-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 600px;
  height: 800px;
}

.share-close {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
  padding: 12rpx 40rpx;
}
