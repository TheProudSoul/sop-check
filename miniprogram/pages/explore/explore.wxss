.container {
  padding-bottom: 40rpx;
  min-height: 100vh;
}

.header {
  padding: 60rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  color: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  display: block;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin: 24rpx 32rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.search-bar input {
  margin-left: 12rpx;
  flex: 1;
  font-size: 28rpx;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e0e0e0;
  border-radius: 50%;
  margin-left: 8rpx;
}

.search-clear-text {
  font-size: 22rpx;
  color: #999;
}

/* 分类横滚 */
.categories {
  white-space: nowrap;
  padding: 0 32rpx 16rpx;
}

.cat-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.cat-active {
  background: #4ecdc4;
  box-shadow: 0 4rpx 12rpx rgba(78,205,196,0.3);
}

.cat-text {
  font-size: 26rpx;
  color: #636e72;
  white-space: nowrap;
}

.cat-active .cat-text {
  color: #fff;
  font-weight: 600;
}

/* SOP列表 */
.sop-list {
  padding: 0 32rpx;
}

.sop-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.sop-emoji {
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f0f7f7;
  border-radius: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.sop-body {
  flex: 1;
  min-width: 0;
}

.sop-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sop-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.sop-tag {
  padding: 2rpx 14rpx;
  background: #f0faf9;
  border-radius: 10rpx;
}

.sop-tag-text {
  font-size: 22rpx;
  color: #4ecdc4;
  font-weight: 500;
}

.sop-meta {
  font-size: 24rpx;
  color: #636e72;
}

.sop-fork-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.fork-icon {
  font-size: 28rpx;
  color: #4ecdc4;
}

.fork-num {
  font-size: 24rpx;
  color: #636e72;
  font-weight: 600;
  margin-top: 2rpx;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4ecdc4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #636e72;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #999;
}
