.container {
  padding-bottom: 40rpx;
  min-height: 100vh;
}

.header {
  padding: 60rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  color: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  display: block;
}

/* 统计概览 — 带渐变底色 */
.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx 0;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
}

.stat-card-blue {
  background: linear-gradient(135deg, #e8f0fe, #d2e3fc);
}

.stat-card-orange {
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
}

.stat-card-green {
  background: linear-gradient(135deg, #e6f8f7, #d0f0ed);
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #4ecdc4;
}

.stat-sop-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #4ecdc4;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4ecdc4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 历史列表 */
.history-list {
  padding: 16rpx 32rpx 0;
}

.date-group {
  margin-bottom: 8rpx;
}

.date-header {
  padding: 20rpx 8rpx 12rpx;
}

.date-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #636e72;
}

.usage-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.usage-emoji {
  font-size: 40rpx;
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: linear-gradient(135deg, #f0faf9, #e8f8f7);
  border-radius: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.usage-body {
  flex: 1;
  min-width: 0;
}

.usage-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3436;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.usage-meta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 8rpx;
}

.usage-time {
  font-size: 24rpx;
  color: #999;
}

.usage-rate {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.rate-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #636e72;
  flex-shrink: 0;
}

.rate-full {
  color: #4ecdc4;
}

.rate-bar {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.rate-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ecdc4, #a8edea);
  border-radius: 4rpx;
  transition: width 0.3s;
  animation: barGrow 0.6s ease-out;
}

@keyframes barGrow {
  from { width: 0 !important; }
}

.usage-check {
  margin-left: 12rpx;
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #4ecdc4;
  border-radius: 50%;
}

.check-mark {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border: 4rpx dashed #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #636e72;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}
