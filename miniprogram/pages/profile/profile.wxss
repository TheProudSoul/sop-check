.container {
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #f7f8fc;
}

/* 顶部个人卡片 */
.profile-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #2d3561 100%);
  padding: 60rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.profile-header::before {
  content: '';
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(78,205,196,0.08);
  top: -100rpx;
  right: -60rpx;
  pointer-events: none;
}

.profile-header::after {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
  bottom: -60rpx;
  left: -40rpx;
  pointer-events: none;
}

.profile-avatar-wrap {
  position: relative;
  z-index: 1;
  margin-bottom: 16rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.profile-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.profile-avatar-emoji {
  font-size: 52rpx;
}

.profile-nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  position: relative;
  z-index: 1;
}

.profile-bio {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
}

.profile-edit-link {
  margin-top: 12rpx;
  position: relative;
  z-index: 10;
  padding: 8rpx 28rpx;
  background: rgba(78,205,196,0.15);
  border-radius: 24rpx;
}

.profile-edit-text {
  font-size: 24rpx;
  color: #4ecdc4;
  font-weight: 500;
}

/* 数据统计 */
.stats-row {
  display: flex;
  margin: -24rpx 32rpx 0;
  padding: 28rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 2;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #4ecdc4;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 菜单列表 */
.menu-list {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: transform 0.15s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  transform: scale(0.98);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-label {
  font-size: 30rpx;
  color: #2d3436;
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4ecdc4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

/* ── 编辑资料弹窗 ── */
.edit-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.edit-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.edit-panel-show {
  transform: translateY(0);
}

.edit-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.edit-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.edit-panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 50%;
}

.edit-panel-close-text {
  font-size: 24rpx;
  color: #999;
}

.edit-panel-body {
  padding: 32rpx;
}

/* 头像选择 */
.edit-avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.edit-avatar-btn {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  border-radius: 50%;
  overflow: visible;
  line-height: normal;
}

.edit-avatar-btn::after {
  display: none;
}

.edit-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #4ecdc4;
}

.edit-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0faf9;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #4ecdc4;
}

.edit-avatar-emoji {
  font-size: 48rpx;
}

.edit-avatar-badge {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #4ecdc4;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.edit-avatar-badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

/* 字段 */
.edit-field {
  margin-bottom: 24rpx;
}

.edit-field-label {
  font-size: 26rpx;
  color: #636e72;
  margin-bottom: 8rpx;
  display: block;
}

.edit-field-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f7f8fc;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #2d3436;
  box-sizing: border-box;
}

.edit-field-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f7f8fc;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #2d3436;
  box-sizing: border-box;
  min-height: 100rpx;
}

/* 保存按钮 */
.edit-save-btn {
  margin-top: 16rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #4ecdc4, #3ab8b0);
  border-radius: 48rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(78,205,196,0.35);
}

.edit-save-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
