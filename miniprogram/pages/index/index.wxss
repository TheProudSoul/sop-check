.container {
  padding-bottom: 180rpx;
  min-height: 100vh;
}

.header {
  padding: 80rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #0f1923 0%, #1a2a3a 50%, #16213e 100%);
  color: #fff;
  position: relative;
  overflow: hidden;
}

/* 背景装饰光斑 */
.header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(78,205,196,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: 60rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(78,205,196,0.08) 0%, transparent 70%);
  border-radius: 50%;
}

/* 品牌横排 */
.brand-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

/* Logo 图标 */
.logo-mark {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #4ecdc4 0%, #44b8b0 100%);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.35);
  transform: rotate(-6deg);
  flex-shrink: 0;
}

.logo-check {
  font-size: 48rpx;
  color: #fff;
  font-weight: 800;
  transform: rotate(6deg);
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.15);
}

/* 品牌文字 */
.brand-text {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  display: block;
  letter-spacing: 4rpx;
  background: linear-gradient(90deg, #fff 0%, #e0f7f5 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 4rpx;
  display: block;
  letter-spacing: 8rpx;
  font-weight: 300;
}

/* Slogan 细线动画 */
.slogan-line {
  margin-top: 24rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(78,205,196,0.6), transparent);
  animation: sloganGlow 3s ease-in-out infinite;
  position: relative;
  z-index: 1;
}

@keyframes sloganGlow {
  0%, 100% { opacity: 0.3; transform: scaleX(0.5); }
  50% { opacity: 1; transform: scaleX(1); }
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 24rpx 32rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.search-bar input {
  margin-left: 12rpx;
  flex: 1;
  font-size: 28rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  margin: 0 32rpx 16rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #636e72;
  border-radius: 36rpx;
  transition: all 0.2s;
}

.tab-active {
  background: #4ecdc4;
  color: #fff;
  font-weight: 600;
}

/* SOP列表 */
.sop-list {
  padding: 0 32rpx;
}

.sop-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  transition: transform 0.15s ease;
}

.sop-card:active {
  transform: scale(0.98);
}

.sop-card-left {
  margin-right: 20rpx;
}

.sop-emoji {
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 16rpx;
}

/* 不同优先级的渐变背景 */
.sop-emoji-default {
  background: linear-gradient(135deg, #f0f7f7, #e0f0ef);
}
.sop-emoji-must {
  background: linear-gradient(135deg, #fff0f0, #ffe0e0);
}
.sop-emoji-optional {
  background: linear-gradient(135deg, #fff8e0, #ffefc0);
}

.sop-card-body {
  flex: 1;
}

.sop-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sop-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.forked-badge {
  display: flex;
  align-items: center;
  padding: 2rpx 12rpx;
  background: #f0f7f7;
  border-radius: 12rpx;
}

.forked-badge-icon {
  font-size: 20rpx;
  color: #4ecdc4;
  margin-right: 4rpx;
}

.forked-badge-text {
  font-size: 20rpx;
  color: #4ecdc4;
  font-weight: 500;
}

.sop-sub-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}

.sop-meta {
  font-size: 24rpx;
  color: #636e72;
}

.sop-group-preview {
  font-size: 22rpx;
  color: #4ecdc4;
  padding: 2rpx 14rpx;
  background: #f0faf9;
  border-radius: 16rpx;
  font-weight: 500;
}

.sop-author-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
}

.sop-author-avatar {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

.sop-author-avatar-placeholder {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.sop-author-name {
  font-size: 22rpx;
  color: #999;
}

.sop-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
  display: block;
}

.sop-card-right {
  margin-left: 16rpx;
}

/* 圆形打勾按钮 */
.sop-use-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #4ecdc4;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(78,205,196,0.3);
  transition: transform 0.15s ease;
}

.sop-use-btn:active {
  transform: scale(0.9);
}

.sop-use-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border: 4rpx dashed #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #636e72;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* FAB 按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: #4ecdc4;
  color: #fff;
  font-size: 52rpx;
  font-weight: 300;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.4);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.4); }
  50% { box-shadow: 0 8rpx 40rpx rgba(78,205,196,0.6); }
}
