.container {
  padding-bottom: 180rpx;
  min-height: 100vh;
}

.header {
  padding: 60rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  color: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  display: block;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 24rpx 32rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.search-bar input {
  margin-left: 12rpx;
  flex: 1;
  font-size: 28rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  margin: 0 32rpx 16rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #636e72;
  border-radius: 36rpx;
  transition: all 0.2s;
}

.tab-active {
  background: #4ecdc4;
  color: #fff;
  font-weight: 600;
}

/* SOP列表 */
.sop-list {
  padding: 0 32rpx;
}

.sop-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.sop-card-left {
  margin-right: 20rpx;
}

.sop-emoji {
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f0f7f7;
  border-radius: 16rpx;
}

.sop-card-body {
  flex: 1;
}

.sop-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sop-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.forked-badge {
  display: flex;
  align-items: center;
  padding: 2rpx 12rpx;
  background: #f0f7f7;
  border-radius: 12rpx;
}

.forked-badge-icon {
  font-size: 20rpx;
  color: #4ecdc4;
  margin-right: 4rpx;
}

.forked-badge-text {
  font-size: 20rpx;
  color: #4ecdc4;
  font-weight: 500;
}

.sop-meta {
  font-size: 24rpx;
  color: #636e72;
  margin-top: 6rpx;
  display: block;
}

.sop-card-right {
  margin-left: 16rpx;
}

.sop-use-btn {
  padding: 12rpx 28rpx;
  background: #4ecdc4;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #636e72;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: #4ecdc4;
  color: #fff;
  font-size: 52rpx;
  font-weight: 300;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.4);
}
