<view class="container">
  <!-- 顶部品牌区 -->
  <view class="header header-curved">
    <view class="brand-row">
      <view class="logo-mark">
        <text class="logo-check">✓</text>
      </view>
      <view class="brand-text">
        <text class="title">勾GO</text>
        <text class="subtitle">勾完再走</text>
      </view>
    </view>
    <view class="slogan-line"/>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <icon type="search" size="14" color="#999"/>
    <input placeholder="搜索SOP..." bindinput="onSearch" value="{{searchText}}"/>
  </view>

  <!-- Tab切换 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'mine' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="mine">
      <text>我的SOP</text>
    </view>
    <view class="tab {{activeTab === 'forked' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="forked">
      <text>Fork来的</text>
    </view>
  </view>

  <!-- SOP列表 -->
  <view class="sop-list" wx:if="{{filteredSops.length > 0}}">
    <view class="sop-card hover-scale animate-in" wx:for="{{filteredSops}}" wx:key="_id" bindtap="goToSop" data-id="{{item._id}}">
      <view class="sop-card-left">
        <view class="sop-emoji sop-emoji-{{item.priority || 'default'}}">{{item.emoji || '📋'}}</view>
      </view>
      <view class="sop-card-body">
        <view class="sop-name-row">
          <text class="sop-name">{{item.title}}</text>
          <view class="forked-badge" wx:if="{{item.forked_from}}">
            <text class="forked-badge-icon">⑂</text>
            <text class="forked-badge-text">Fork</text>
          </view>
        </view>
        <view class="sop-sub-row">
          <text class="sop-meta">{{totalItemCount(item)}} 项</text>
          <text class="sop-group-preview" wx:if="{{item.groupPreview}}">{{item.groupPreview}}</text>
        </view>
        <view class="sop-author-row" wx:if="{{item.author_name}}">
          <image class="sop-author-avatar" src="{{item.author_avatar || '/assets/default-avatar.png'}}" mode="aspectFill" wx:if="{{item.author_avatar}}"/>
          <view class="sop-author-avatar-placeholder" wx:else/>
          <text class="sop-author-name">{{item.author_name === (userInfo.nickname || '勾友') ? '我' : item.author_name}}</text>
        </view>
        <text class="sop-time" wx:if="{{item.timeAgo}}">{{item.timeAgo}}</text>
      </view>
      <view class="sop-card-right">
        <view class="sop-use-btn" catchtap="startCheck" data-id="{{item._id}}">
          <text class="sop-use-icon">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{filteredSops.length === 0 && !searchText && activeTab === 'mine'}}">
    <view class="empty-circle">
      <text class="empty-icon">📦</text>
    </view>
    <text class="empty-text">还没有SOP</text>
    <text class="empty-hint">点击下方 + 创建第一份</text>
  </view>

  <view class="empty" wx:if="{{filteredSops.length === 0 && !searchText && activeTab === 'forked'}}">
    <view class="empty-circle">
      <text class="empty-icon">⑂</text>
    </view>
    <text class="empty-text">还没有Fork来的SOP</text>
    <text class="empty-hint">让朋友分享一份SOP给你</text>
  </view>

  <!-- 搜索空 -->
  <view class="empty" wx:if="{{filteredSops.length === 0 && searchText}}">
    <text class="empty-text">没找到"{{searchText}}"相关的SOP</text>
  </view>

  <!-- 创建按钮 -->
  <view class="fab" bindtap="createSop">+</view>
</view>
